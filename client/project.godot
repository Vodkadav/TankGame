; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes in []
;   param=value ; simple (single-line) values
;   param={"key": "value", ...} ; dictionary values

config_version=5

[application]

config/name="TankGame"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
run/main_scene="res://Main.tscn"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[dotnet]

project/assembly_name="TankGame"

[internationalization]

locale/translations_pot_files=PackedStringArray("res://i18n/strings.csv")
locale/test="en"

[physics]

common/physics_interpolation=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
