; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows for manual editing.
; https://docs.godotengine.org/en/stable/tutorials/export/exporting_projects.html

config_version=5

[application]

config/name="TankGame"
config/name_localized={
"da": "TankGame",
"en": "TankGame",
"es": "TankGame"
}
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.6", "C#", "Mobile")
config/icon="res://icon.svg"

[dotnet]

project/assembly_name="TankGame"

[internationalization]

locale/translations=PackedStringArray("res://i18n/strings.en.translation", "res://i18n/strings.es.translation", "res://i18n/strings.da.translation")
