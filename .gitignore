# Godot — commit .uid (script) and .import (resource) files so UIDs stay stable across
# machines/checkouts (Godot reuses them instead of minting new ones, which avoids scene-
# reference drift). Only the reimport cache, mono glue, compiled translations, and export
# output are ignored — all regenerated from source on import/build.
.godot/
mono/
*.translation
/build/
# Gradle custom-build template — installed fresh per-build (CI: --install-android-build-template)
client/android/

# .NET
bin/
obj/
*.user

# Node / pnpm
node_modules/
.pnpm-store/
dist/

# Cloudflare
.wrangler/
.dev.vars

# Environment
.env
.env.local

# Sentry CLI
.sentryclirc

# Claude Code local/session dirs (ephemeral, per-machine — never committed)
.claude/plans/
.claude/worktrees/
.claude/settings.local.json

# Art working area + extracted source asset packs (only processed outputs are committed)
art-wip/
kenney_*

# …but asset-browser imports are processed outputs: pack-named folders under imported/ DO commit
!client/src/Presentation/Arena/models/imported/kenney_*/
!client/src/Presentation/Arena/models/imported/kenney_*/**

# Local web-export smoke artifacts (regenerated by the export; never committed)
live.pck
live.wasm
